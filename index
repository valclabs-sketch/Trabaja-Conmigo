<script>
  // Scroll reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(r => obs.observe(r));

  // Nav shadow
  window.addEventListener('scroll', () => {
    document.getElementById('main-nav').classList.toggle('scrolled', window.scrollY > 30);
  });

  // Form → mailto
  function sendEmail() {
    const name    = document.getElementById('fname').value.trim();
    const company = document.getElementById('fcompany').value.trim();
    const email   = document.getElementById('femail').value.trim();
    const service = document.getElementById('fservice').value;
    const budget  = document.getElementById('fbudget').value;
    const message = document.getElementById('fmessage').value.trim();

    if (!name || !email || !service || !budget || !message) {
      alert('Por favor completa todos los campos marcados con *.');
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      alert('Por favor ingresa un correo electrónico válido.');
      return;
    }

    const subject = encodeURIComponent(`[ValClabs] Consulta de ${name} — ${service}`);
    const body = encodeURIComponent(
`Hola Valentina,

He completado el formulario en tu página web y quisiera hablar sobre un proyecto.

━━━━━━━━━━━━━━━━━━━━━━
DATOS DE CONTACTO
━━━━━━━━━━━━━━━━━━━━━━
Nombre:      ${name}
Empresa:     ${company || 'No indicada'}
Mi correo:   ${email}

━━━━━━━━━━━━━━━━━━━━━━
PROYECTO
━━━━━━━━━━━━━━━━━━━━━━
Servicio:    ${service}
Presupuesto: ${budget}

━━━━━━━━━━━━━━━━━━━━━━
DESCRIPCIÓN
━━━━━━━━━━━━━━━━━━━━━━
${message}

━━━━━━━━━━━━━━━━━━━━━━
(Enviado desde la landing page de ValClabs)`
    );

    window.location.href = `mailto:valclabs@gmail.com?subject=${subject}&body=${body}`;

    setTimeout(() => {
      document.getElementById('form-body').style.display = 'none';
      document.getElementById('form-success').style.display = 'block';
    }, 700);
  }
</script>

